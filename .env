# API endpoints
CHAT_API=http://chat:8000
EMBEDDING_API=http://embedding:8000
TTS_API=http://tts:8000
STT_API=http://stt:8000
LICENSE_API=http://license:8000

# ports
CONTROL_PORT=8000

# GPU
NVIDIA_VISIBLE_DEVICES=all
CHAT_GPU_ID=0
EMBEDDING_GPU_ID=0
STT_GPU_ID=0
TTS_GPU_ID=0

# compose state
COMPOSE_STATE_PATH=./compose_state.json

#docker
COMPOSE_PATH=./docker-compose-in-docker.yml
COMPOSE_LOCAL_PATH=./docker-compose-local-in-docker.yml

#env
ENV_PATH=./.env

# chat model
CHAT_MODEL=Qwen/Qwen2.5-7B-Instruct-GPTQ-Int8
CHAT_MODEL_PATH=./services/chat/models/
CHAT_MODEL_PATH_IN_CONTROL=${PWD}\services\chat\models\
CHAT_GPU_UTIL=0.6

# embedding
EMBEDDING_MODEL=infly/inf-retriever-v1-1.5b
EMBEDDING_MODEL_PATH=./services/embedding/models/
EMBEDDING_MODEL_PATH_IN_CONTROL=${PWD}\services\embedding\models\

# tts
TTS_MODEL=FunAudioLLM/CosyVoice2-0.5B
TTS_MODEL_PATH=./services/tts/models/
TTS_MODEL_PATH_IN_CONTROL=${PWD}\services\tts\models\
TTS_ASSET_PATH=./services/tts/asset/
TTS_ASSET_PATH_IN_CONTROL=${PWD}\services\tts\asset\

# stt
STT_MODEL=Systran/faster-distil-whisper-large-v3
STT_MODEL_PATH=./services/stt/models/
STT_MODEL_PATH_IN_CONTROL=${PWD}\services\stt\models\

# docker
IN_DOCKER_USE_DOCKER=/var/run/docker.sock:/var/run/docker.sock

# build
BUILD_CHAT_IN_CONTROL=${PWD}\services\chat
BUILD_EMBEDDING_IN_CONTROL=${PWD}\services\embedding
BUILD_TTS_IN_CONTROL=${PWD}\services\tts
BUILD_STT_IN_CONTROL=${PWD}\services\stt
BUILD_CONTROL_IN_CONTROL=${PWD}\services\contorl
BUILD_LICNESE_IN_CONTROL=${PWD}\services\license
BUILD_DIR=${PWD}