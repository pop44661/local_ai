# API endpoints
CHAT_API=http://chat:8000
EMBEDDING_API=http://embedding:8000
TTS_API=http://tts:8000
STT_API=http://stt:8000

# ports
CONTROL_PORT=8000

# GPU
NVIDIA_VISIBLE_DEVICES=all

# compose state
COMPOSE_STATE_PATH=./services/control/app/static/app/compose_state.json

#env
ENV_PATH=./.env

# chat model
CHAT_MODEL=Qwen2.5/Qwen2.5-7B-Instruct-GPTQ-Int8
CHAT_MODEL_PATH=./services/chat/models
CHAT_GPU_UTIL=0.6

# embedding
EMBEDDING_MODEL=infly/inf-retriever-v1-1.5b
EMBEDDING_MODEL_PATH=./services/embedding/models

# tts
TTS_MODEL=FunAudioLLM/CosyVoice2-0.5B
TTS_MODEL_PATH=./services/tts/models
TTS_ASSET_PATH=./services/tts/asset

# stt
STT_MODEL=Systran/faster-distil-whisper-large-v3
STT_MODEL_PATH=./services/stt/models

# docker
IN_DOCKER_USE_DOCKER=/var/run/docker.sock:/var/run/docker.sock